<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # السماح بالوصول المباشر للملفات الموجودة
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # إعادة توجيه الطلبات غير الموجودة إلى index.php فقط
    RewriteRule ^(.*)$ index.php [L]
</IfModule>
